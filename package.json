{
  "name": "teamup-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "prestart": "prisma migrate deploy && prisma generate",
    "start": "node src/server.js",
    "test": "npm run test:all",
    "test:all": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config tests/config/jest.all.config.js --runInBand",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config tests/config/jest.unit.config.js",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config tests/config/jest.integration.config.js --runInBand",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config tests/config/jest.all.config.js --runInBand --coverage",
    "test:cleanup": "node tests/cleanup-containers.js",
    "lint": "npm run lint:js && npm run lint:docs:english && npm run check:swagger-joi",
    "lint:js": "eslint .",
    "lint:docs:english": "node scripts/lint-docs-english.mjs",
    "check:swagger-joi": "node scripts/check-swagger-joi-consistency.mjs",
    "format:base": "prettier --write --ignore-unknown",
    "format": "npm run format:base -- .",
    "prepare": "husky",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:clean": "node prisma/clean.js",
    "db:seed": "node prisma/seed.js",
    "db:seed:clean": "node prisma/seed-clean.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "lint-staged": {
    "*": "npm run format:base --"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "pg": "^8.12.0",
    "prisma": "^7.0.0",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "husky": "^9.1.5",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "supertest": "^6.3.4",
    "testcontainers": "^10.13.2"
  }
}
