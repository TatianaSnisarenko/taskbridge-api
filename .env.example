# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://teamup:teamup@localhost:5432/teamup?schema=public"

# JWT and refresh tokens
JWT_ACCESS_SECRET="change_me_access_secret"
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# CORS
CLIENT_ORIGIN=http://localhost:5173,http://localhost:3000

# Email / SMTP
EMAIL_ADDRESS=example@domain.com
EMAIL_PASSWORD=change_me_email_password
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_OUTBOX_ENABLED=true

# Email outbox worker and cleanup schedules
EMAIL_OUTBOX_WORKER_CRON=*/1 * * * *
EMAIL_OUTBOX_CLEANUP_CRON=17 2 * * *

# Email outbox retry policy
EMAIL_OUTBOX_BATCH_SIZE=20
EMAIL_OUTBOX_MAX_ATTEMPTS=8
EMAIL_OUTBOX_MESSAGE_TTL_HOURS=24
EMAIL_OUTBOX_BASE_DELAY_MS=5000
EMAIL_OUTBOX_MAX_DELAY_MS=900000
EMAIL_OUTBOX_JITTER_RATIO=0.3
EMAIL_OUTBOX_PROCESSING_TIMEOUT_MS=120000
EMAIL_OUTBOX_WORKER_LOCK_TTL_MS=55000
EMAIL_OUTBOX_THROTTLE_BATCH_PAUSE_MS=60000

# Email outbox retention
EMAIL_OUTBOX_SENT_RETENTION_DAYS=7
EMAIL_OUTBOX_FAILED_RETENTION_DAYS=14

# App URLs
APP_BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:5173

# Verification and password reset
EMAIL_VERIFICATION_TTL_HOURS=24
VERIFICATION_TOKEN_RETENTION_DAYS=7
UNVERIFIED_USER_DELETION_AFTER_DAYS=7
UNVERIFIED_USER_CLEANUP_CRON=43 3 * * *
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=change_me_cloudinary_secret

# Platform workflow settings
PLATFORM_REVIEW_COOLDOWN_DAYS=30
TASK_COMPLETION_RESPONSE_HOURS=72

# Redis cache (optional - enables candidate count caching and other optimizations)
# Set REDIS_ENABLED=true to enable Redis caching in local development
REDIS_ENABLED=false
# Set REDIS_REQUIRED=true to fail server startup when Redis is unavailable
REDIS_URL=redis://localhost:6379
REDIS_REQUIRED=false
REDIS_CONNECT_TIMEOUT_MS=3000
REDIS_STARTUP_RETRIES=3
REDIS_RETRY_DELAY_MS=500

# Cache TTL settings (time-to-live in seconds)
# Candidate count cache: how long to cache filtered candidate counts per task
CANDIDATE_CACHE_TTL_SECONDS=3600
# Technologies search cache (autocomplete and by-id lookups)
TECHNOLOGY_SEARCH_CACHE_TTL_SECONDS=300
TECHNOLOGY_BY_ID_CACHE_TTL_SECONDS=3600
# Notifications unread badge cache
NOTIFICATION_UNREAD_CACHE_TTL_SECONDS=30
# Public tasks catalog cache
TASK_CATALOG_PUBLIC_CACHE_TTL_SECONDS=60
# Public projects catalog cache
PROJECTS_CATALOG_PUBLIC_CACHE_TTL_SECONDS=90
# Invites list cache (task invites + my invites)
INVITES_CATALOG_CACHE_TTL_SECONDS=45
# My threads list preview cache
THREADS_CATALOG_CACHE_TTL_SECONDS=30

# Optional admin bootstrap for seeding
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_admin_password
