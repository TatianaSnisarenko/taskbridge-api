generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ExperienceLevel {
  STUDENT
  JUNIOR
  MIDDLE
  SENIOR
}

enum Availability {
  FEW_HOURS_WEEK
  PART_TIME
  FULL_TIME
}

enum TechnologyType {
  BACKEND
  FRONTEND
  DEVOPS
  QA
  DATA
  MOBILE
  OTHER
  FULLSTACK
  AI_ML
  UI_UX_DESIGN
  PRODUCT_MANAGEMENT
  BUSINESS_ANALYSIS
  CYBERSECURITY
  GAME_DEV
  EMBEDDED
  TECH_WRITING
}

enum TaskType {
  PAID
  UNPAID
  VOLUNTEER
  EXPERIENCE
}

enum TaskDifficulty {
  JUNIOR
  MIDDLE
  SENIOR
  ANY
}

enum TaskDuration {
  DAYS_1_7
  DAYS_8_14
  DAYS_15_30
  DAYS_30_PLUS
}

enum TaskVisibility {
  PUBLIC
  UNLISTED
}

enum TaskStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETION_REQUESTED
  COMPLETED
  FAILED
  CLOSED
  DELETED
}

enum ApplicationStatus {
  APPLIED
  ACCEPTED
  REJECTED
}

enum Persona {
  developer
  company
}

enum CompanyType {
  STARTUP
  SMB
  ENTERPRISE
  INDIVIDUAL
}

enum NotificationType {
  APPLICATION_CREATED
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  COMPLETION_REQUESTED
  TASK_COMPLETED
  REVIEW_CREATED
  CHAT_MESSAGE
}

enum VerificationType {
  EMAIL_VERIFY
  PASSWORD_RESET
  EMAIL_CHANGE
}

enum TechnologySuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum ProjectVisibility {
  PUBLIC
  UNLISTED
}

enum ProjectReportReason {
  SPAM
  SCAM
  INAPPROPRIATE_CONTENT
  MISLEADING
  OTHER
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]
  developerProfile   DeveloperProfile?
  companyProfile     CompanyProfile?

  ownedProjects Project[] @relation("ProjectOwner")
  ownedTasks    Task[]    @relation("TaskOwner")

  applications Application[] @relation("ApplicationDeveloper")

  sentMessages ChatMessage[]

  authoredReviews Review[] @relation("ReviewAuthor")
  receivedReviews Review[] @relation("ReviewTarget")

  notifications      Notification[] @relation("NotificationRecipient")
  actedNotifications Notification[] @relation("NotificationActor")

  projectReports ProjectReport[] @relation("ProjectReportReporter")

  chatThreadReads ChatThreadRead[] @relation("ChatThreadRead")

  @@map("users")
}

model VerificationToken {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      VerificationType
  tokenHash String           @unique @map("token_hash")
  expiresAt DateTime         @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime?        @map("used_at") @db.Timestamptz(6)
  email     String?
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, expiresAt(sort: Desc)])
  @@map("verification_tokens")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  deviceInfo String?   @map("device_info")
  ip         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt(sort: Desc)])
  @@map("refresh_tokens")
}

model DeveloperProfile {
  userId                  String           @id @map("user_id") @db.Uuid
  displayName             String           @map("display_name")
  jobTitle                String           @default("") @map("primary_role")
  bio                     String           @default("")
  experienceLevel         ExperienceLevel? @map("experience_level")
  location                String?
  timezone                String?
  skills                  String[]         @default([])
  techStack               String[]         @default([]) @map("tech_stack")
  availability            Availability?
  preferredTaskCategories TechnologyType[] @default([]) @map("preferred_task_categories")
  portfolioUrl            String?          @map("portfolio_url")
  githubUrl               String?          @map("github_url")
  linkedinUrl             String?          @map("linkedin_url")
  avatarUrl               String?          @map("avatar_url")
  avatarPublicId          String?          @map("avatar_public_id")
  avgRating               Decimal          @default(0) @map("avg_rating") @db.Decimal(2, 1)
  reviewsCount            Int              @default(0) @map("reviews_count")
  createdAt               DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  technologies DeveloperTechnology[]

  @@map("developer_profiles")
}

model CompanyProfile {
  userId       String       @id @map("user_id") @db.Uuid
  companyName  String       @map("company_name")
  companyType  CompanyType? @map("company_type")
  description  String       @default("")
  teamSize     Int?         @map("team_size")
  country      String?
  timezone     String?
  logoUrl      String?      @map("logo_url")
  logoPublicId String?      @map("logo_public_id")
  contactEmail String?      @map("contact_email")
  websiteUrl   String?      @map("website_url")
  links        Json         @default("{}")
  verified     Boolean      @default(false)
  avgRating    Decimal      @default(0) @map("avg_rating") @db.Decimal(2, 1)
  reviewsCount Int          @default(0) @map("reviews_count")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

model Project {
  id                  String            @id @default(uuid()) @db.Uuid
  ownerUserId         String            @map("owner_user_id") @db.Uuid
  status              ProjectStatus     @default(ACTIVE)
  visibility          ProjectVisibility @default(PUBLIC)
  title               String
  shortDescription    String            @default("") @map("short_description")
  description         String            @default("")
  technologies        String[]          @default([])
  maxTalents          Int               @default(1) @map("max_talents")
  publishedTasksCount Int               @default(0) @map("published_tasks_count")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?         @map("deleted_at") @db.Timestamptz(6)

  owner   User            @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  tasks   Task[]
  reports ProjectReport[]

  notifications Notification[]

  @@unique([ownerUserId, title])
  @@index([ownerUserId, createdAt(sort: Desc)])
  @@index([visibility, deletedAt, createdAt(sort: Desc)])
  @@index([deletedAt, createdAt(sort: Desc)])
  @@map("projects")
}

model ProjectReport {
  id              String              @id @default(uuid()) @db.Uuid
  projectId       String              @map("project_id") @db.Uuid
  reporterUserId  String              @map("reporter_user_id") @db.Uuid
  reporterPersona Persona             @map("reporter_persona")
  reason          ProjectReportReason
  comment         String?             @default("")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter User    @relation("ProjectReportReporter", fields: [reporterUserId], references: [id], onDelete: Cascade)

  @@unique([projectId, reporterUserId])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([reporterUserId, createdAt(sort: Desc)])
  @@map("project_reports")
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  ownerUserId String     @map("owner_user_id") @db.Uuid
  status      TaskStatus @default(DRAFT)

  projectId String? @map("project_id") @db.Uuid

  title          String
  description    String
  category       TechnologyType?
  type           TaskType        @default(EXPERIENCE)
  difficulty     TaskDifficulty?
  requiredSkills String[]        @default([]) @map("required_skills")

  estimatedEffortHours  Int?           @map("estimated_effort_hours")
  expectedDuration      TaskDuration?  @map("expected_duration")
  communicationLanguage String?        @map("communication_language")
  timezonePreference    String?        @map("timezone_preference")
  applicationDeadline   DateTime?      @map("application_deadline") @db.Date
  visibility            TaskVisibility @default(PUBLIC)

  deliverables String @default("")
  requirements String @default("")
  niceToHave   String @default("") @map("nice_to_have")

  acceptedApplicationId String? @unique @map("accepted_application_id") @db.Uuid

  rejectionCount Int @default(0) @map("rejection_count")

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  publishedAt DateTime? @map("published_at") @db.Timestamptz(6)
  closedAt    DateTime? @map("closed_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  failedAt    DateTime? @map("failed_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  owner               User             @relation("TaskOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  project             Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  applications        Application[]
  acceptedApplication Application?     @relation("AcceptedApplication", fields: [acceptedApplicationId], references: [id])
  chatThread          ChatThread?
  reviews             Review[]
  technologies        TaskTechnology[]

  notifications Notification[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([ownerUserId, createdAt(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([deletedAt, createdAt(sort: Desc)])
  @@index([projectId, deletedAt, createdAt(sort: Desc)])
  @@map("tasks")
}

model Application {
  id               String            @id @default(uuid()) @db.Uuid
  taskId           String            @map("task_id") @db.Uuid
  developerUserId  String            @map("developer_user_id") @db.Uuid
  status           ApplicationStatus
  message          String?
  proposedPlan     String?           @map("proposed_plan")
  availabilityNote String?           @map("availability_note")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  task            Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  developer       User  @relation("ApplicationDeveloper", fields: [developerUserId], references: [id], onDelete: Cascade)
  acceptedForTask Task? @relation("AcceptedApplication")

  @@unique([taskId, developerUserId])
  @@index([taskId, createdAt(sort: Desc)])
  @@index([developerUserId, createdAt(sort: Desc)])
  @@map("applications")
}

model ChatThread {
  id              String    @id @default(uuid()) @db.Uuid
  taskId          String    @map("task_id") @db.Uuid
  companyUserId   String    @map("company_user_id") @db.Uuid
  developerUserId String    @map("developer_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastMessageAt   DateTime? @map("last_message_at") @db.Timestamptz(6)

  task     Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
  reads    ChatThreadRead[] @relation("ChatThreadRead")

  notifications Notification[]

  @@unique([taskId])
  @@index([companyUserId, lastMessageAt(sort: Desc)])
  @@index([developerUserId, lastMessageAt(sort: Desc)])
  @@map("chat_threads")
}

model ChatMessage {
  id            String   @id @default(uuid()) @db.Uuid
  threadId      String   @map("thread_id") @db.Uuid
  senderUserId  String   @map("sender_user_id") @db.Uuid
  senderPersona Persona? @map("sender_persona")
  text          String   @db.VarChar(2000)
  sentAt        DateTime @default(now()) @map("sent_at") @db.Timestamptz(6)

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User       @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([threadId, sentAt(sort: Desc)])
  @@map("chat_messages")
}

model ChatThreadRead {
  threadId   String   @map("thread_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  lastReadAt DateTime @map("last_read_at") @db.Timestamptz(6)

  thread ChatThread @relation("ChatThreadRead", fields: [threadId], references: [id], onDelete: Cascade)
  user   User       @relation("ChatThreadRead", fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
  @@index([userId])
  @@map("chat_thread_reads")
}

model Review {
  id           String   @id @default(uuid()) @db.Uuid
  taskId       String   @map("task_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  targetUserId String   @map("target_user_id") @db.Uuid
  rating       Int
  text         String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("ReviewAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  target User @relation("ReviewTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([taskId, authorUserId])
  @@index([targetUserId, createdAt(sort: Desc)])
  @@map("reviews")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  actorUserId String?          @map("actor_user_id") @db.Uuid
  projectId   String?          @map("project_id") @db.Uuid
  taskId      String?          @map("task_id") @db.Uuid
  threadId    String?          @map("thread_id") @db.Uuid
  type        NotificationType
  payload     Json             @default("{}")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt      DateTime?        @map("read_at") @db.Timestamptz(6)

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  project Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task    Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  thread  ChatThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([taskId, createdAt(sort: Desc)])
  @@index([threadId, createdAt(sort: Desc)])
  @@map("notifications")
}

model Technology {
  id              String         @id @default(uuid()) @db.Uuid
  slug            String         @unique
  name            String
  type            TechnologyType
  isActive        Boolean        @default(true) @map("is_active")
  popularityScore Int            @default(0) @map("popularity_score")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  developers  DeveloperTechnology[]
  tasks       TaskTechnology[]
  suggestions TechnologySuggestion[]

  @@index([type, popularityScore(sort: Desc)])
  @@index([slug])
  @@index([isActive])
  @@map("technologies")
}

model DeveloperTechnology {
  id               String   @id @default(uuid()) @db.Uuid
  developerUserId  String   @map("developer_user_id") @db.Uuid
  technologyId     String   @map("technology_id") @db.Uuid
  proficiencyYears Int?     @default(0) @map("proficiency_years")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  developer  DeveloperProfile @relation(fields: [developerUserId], references: [userId], onDelete: Cascade)
  technology Technology       @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@unique([developerUserId, technologyId])
  @@index([developerUserId])
  @@map("developer_technologies")
}

model TaskTechnology {
  id           String   @id @default(uuid()) @db.Uuid
  taskId       String   @map("task_id") @db.Uuid
  technologyId String   @map("technology_id") @db.Uuid
  isRequired   Boolean  @default(true) @map("is_required")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@unique([taskId, technologyId])
  @@index([taskId])
  @@map("task_technologies")
}

model TechnologySuggestion {
  id            String                     @id @default(uuid()) @db.Uuid
  technologyId  String                     @map("technology_id") @db.Uuid
  suggestedName String                     @map("suggested_name")
  suggestedSlug String                     @map("suggested_slug")
  suggestedType TechnologyType             @map("suggested_type")
  suggestedBy   String?                    @map("suggested_by") @db.Uuid
  status        TechnologySuggestionStatus @default(PENDING)
  reviewedBy    String?                    @map("reviewed_by") @db.Uuid
  reviewComment String?                    @map("review_comment")
  createdAt     DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  reviewedAt    DateTime?                  @map("reviewed_at") @db.Timestamptz(6)

  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@index([status, createdAt(sort: Desc)])
  @@index([technologyId])
  @@map("technology_suggestions")
}
